{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "agnes-ai",
  "main": "worker/index.js",
  "compatibility_date": "2025-06-13",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/agnes/*"
    ]
  },
  "routes": [
    {
      "pattern": "agnes.fanko.kdns.fr",
      "custom_domain": true
    }
  ]
}
